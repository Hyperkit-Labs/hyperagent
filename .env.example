NODE_ENV=production
LOG_LEVEL=INFO

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
DATABASE_URL=

# --- Redis (gateway rate limit; use rediss:// for TLS) ---
REDIS_URL=
# Set false if Redis TLS cert verification fails (e.g. Supabase/Redis Cloud)
REDIS_TLS_VERIFY=true
# Set true to allow requests when Redis is unreachable (bypass rate limit)
RATE_LIMIT_BYPASS_ON_FAIL=false
# Per-IP and per-user limits per 60s (defaults: 300 IP, 500 user; increase if Payments page hits 429)
RATE_LIMIT_MAX_IP=300
RATE_LIMIT_MAX_USER=500

# --- Tenderly (simulation) ---
TENDERLY_API_KEY=
TENDERLY_ACCOUNT=
TENDERLY_PROJECT=
TENDERLY_API_URL=

# --- Thirdweb / x402 ---
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=
THIRDWEB_SECRET_KEY=
THIRDWEB_SERVER_WALLET_ADDRESS=
MERCHANT_WALLET_ADDRESS=
X402_ENABLED=true

# --- Credits (orchestrator) ---
CREDITS_ENABLED=
CREDITS_PER_USD=10
CREDITS_PER_RUN=7

# --- Pinata (IPFS) ---
PINATA_JWT=
PINATA_TEMPLATE_ID=
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_GATEWAY_BASE=https://gateway.pinata.cloud/ipfs

# --- Chain registry ---
REGISTRIES_PATH=./infra/registries
CHAIN_REGISTRY_PATH=./infra/registries/network/chains.yaml

# --- Services (cross-service URLs) ---
ORCHESTRATOR_URL=
AGENT_RUNTIME_URL=
VECTORDB_URL=
STORAGE_SERVICE_URL=
COMPILE_SERVICE_URL=
AUDIT_SERVICE_URL=
SIMULATION_SERVICE_URL=
DEPLOY_SERVICE_URL=
TOOLS_BASE_URL=
ROMA_URL=
OPENSANDBOX_API_URL=https://api.opensandbox.ai
# --- Studio (frontend) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_DOCS_URL=

# --- Shared secrets (openssl rand -base64 32); security is mandatory ---
TOOLS_API_KEY=
# Same value on orchestrator and agent-runtime for service-to-service auth (X-Internal-Token)
INTERNAL_SERVICE_TOKEN=
AGENT_SESSION_PAYLOAD_KEY=
JWT_SECRET_KEY=
LLM_KEY_ENCRYPTION_KEY=
AUTH_JWT_SECRET=
AUTH_JWT_EXPIRES_IN=86400
# Auth enforced by default; set false only for local dev when needed
REQUIRE_AUTH=true

# --- SCRUBD (mandatory RE/UX validation) ---
SCRUBD_PATH=./data/SCRUBD
SCRUBD_VERSION=V6.0

# --- SCV sync (weekly Hugging Face -> RAG) ---
SCV_SYNC_ENABLED=true

# --- Exploit simulation (DeFiHackLabs PoC tests;) ---
EXPLOIT_SIM_ENABLED=true
DEFIHACKLABS_PATH=./data/DeFiHackLabs

# --- Debate (Proposer + Auditor) ---
MAX_DEBATE_ROUNDS=3

# --- Pashov solidity-auditor (AI-driven security review;) ---
# Requires packages/pashov-skills submodule. Uses BYOK via agent-runtime.
PASHOV_AUDIT_ENABLED=true
PASHOV_SKILLS_PATH=packages/pashov-skills/solidity-auditor

# --- OpenSandbox (high-security backend execution;) ---
# When enabled, compile/audit/exploit_sim run in gVisor/Firecracker sandboxes.
OPENSANDBOX_ENABLED=true
OPENSANDBOX_API_KEY=

# --- Security feed (zero-day resilience) ---
# Fetches recent exploit advisories and indexes for DesignAgent. DeFiLlama is the only public API.
DEFILLAMA_FEED_URL=https://api.llama.fi/hacks
SECURITY_FEED_TIMEOUT=10
SECURITY_FEED_MAX_EXPLOITS=5

# --- Orchestrator (for dynamic source tarball URL) ---
# When quick-demo uses workflow_id, Vercel fetches tarball from this URL. Set to public orchestrator URL when behind proxy.
ORCHESTRATOR_PUBLIC_URL=

# --- Quick Demo (Vercel Sandbox) ---
# See https://vercel.com/docs/vercel-sandbox/concepts/authentication
# Local dev: vercel link && vercel env pull (creates .env.local with VERCEL_OIDC_TOKEN)
# Non-Vercel (Render): VERCEL_SANDBOX_TOKEN or VERCEL_TOKEN + VERCEL_TEAM_ID + VERCEL_PROJECT_ID
VERCEL_SANDBOX_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
DEMO_SANDBOX_SOURCE_URL=https://github.com/NomicFoundation/hardhat-template
DEMO_SANDBOX_SOURCE_TYPE=git

# --- Gateway ---
CORS_ORIGINS=http://localhost:3000 # Replace with your actual domain
