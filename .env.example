NODE_ENV=production
LOG_LEVEL=INFO

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
# Set to 1/true to skip writing security_audit_log rows from orchestrator (structured logs still emit).
# SUPABASE_AUDIT_DISABLE=0

# --- Waiver evidence (orchestrator API: POST .../security-waivers) ---
# HMAC secret for signed waiver payloads. Generate with: openssl rand -hex 32
WAIVER_SIGNING_SECRET=

# Postgres URI. For Supabase use Transaction pooler (Dashboard → Database → Transaction pooler, port 6543, user postgres.<project_ref>).
# Orchestrator and local migrate scripts need this. If DDL migrations fail via pooler, use Session or Direct once for apply-supabase-migrations only.
DATABASE_URL=

# --- Upstash: API gateway rate limits use REST only (@upstash/ratelimit) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# --- TCP Redis (orchestrator queue, LangGraph checkpointer, redis-py) ---
# Use the "redis-cli" / TCP URL from Upstash (redis:// or rediss://). Example:
# REDIS_URL=redis://default:YOUR_TOKEN@modern-imp-71775.upstash.io:6379
REDIS_URL=
# TLS: prefer rediss:// for TCP in production. Set false only if TLS verification fails in a lab.
UPSTASH_REDIS_TLS_VERIFY=true
RATE_LIMIT_BYPASS_ON_FAIL=false
# Per-IP and per-user limits per 60s (defaults: 300 IP, 500 user; increase if Payments page hits 429)
RATE_LIMIT_MAX_IP=300
RATE_LIMIT_MAX_USER=500
RATE_LIMIT_MULTIPLIER=2
# Config/networks/stablecoins (GET). Tiered: unauthenticated=IP limit, authenticated=user limit.
RATE_LIMIT_LIGHT_MAX_IP=100
RATE_LIMIT_LIGHT_MAX_USER=500
# Auth bootstrap: 5 attempts per IP per 60s (prevents brute force). RATE_LIMIT_SIWE_* kept for backward compat.
RATE_LIMIT_BOOTSTRAP_MAX_IP=5
RATE_LIMIT_BOOTSTRAP_WINDOW_SEC=60

# --- Tenderly (simulation) ---
TENDERLY_API_KEY=
TENDERLY_ACCOUNT=
TENDERLY_PROJECT=
TENDERLY_VIRTUAL_RPC_URL=https://virtual.rpc.tenderly.co/hyperkit/project/public/hyperagent
TENDERLY_VIRTUAL_WSS_URL=wss://virtual.rpc.tenderly.co/hyperkit/project/public/hyperagent
TENDERLY_API_URL=
TENDERLY_SIMULATION_REQUIRED=true
# Inbound Tenderly alert webhook: HMAC-SHA256 signing secret. Production requires this when using push.
# POST URL: https://<orchestrator-host>/api/v1/simulation/webhooks/tenderly (header x-tenderly-signature).
TENDERLY_WEBHOOK_SECRET=
SIMULATION_USE_BUNDLE=true

# --- Thirdweb ---
# Frontend only (Studio): public client for wallet connect, chain resolution, deploy.
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=
# Backend only (api-gateway, orchestrator, agent-runtime): never expose to Studio or frontend. Used for thirdweb OAuth token verification (/auth/bootstrap), Engine, backend wallets.
THIRDWEB_SECRET_KEY=
# Gas sponsorship: when NEXT_PUBLIC_SPONSOR_GAS=true, connect uses thirdweb account abstraction (sponsorGas). See portal.thirdweb.com/engine.
THIRDWEB_SERVER_WALLET_ADDRESS=
# Frontend: enable gas sponsorship on connect. Uses Base Sepolia (thirdweb shared) or SKALE (custom factory when set).
NEXT_PUBLIC_SPONSOR_GAS=false

# SKALE AA: official factory at 0x16aE460b084501F9A55Ad7f98c6576a01881Bbc9. See docs/skale-account-factory.md.
NEXT_PUBLIC_SKALE_BASE_SEPOLIA_FACTORY_ADDRESS=0x16aE460b084501F9A55Ad7f98c6576a01881Bbc9
NEXT_PUBLIC_SKALE_BASE_SEPOLIA_BUNDLER_URL=https://324705682.bundler.thirdweb.com
NEXT_PUBLIC_SKALE_BASE_SEPOLIA_ENTRYPOINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789
NEXT_PUBLIC_SKALE_BASE_SEPOLIA_SPONSOR_GAS=true

NEXT_PUBLIC_SKALE_BASE_MAINNET_FACTORY_ADDRESS=
NEXT_PUBLIC_SKALE_BASE_MAINNET_BUNDLER_URL=https://1187947933.bundler.thirdweb.com
NEXT_PUBLIC_SKALE_BASE_MAINNET_ENTRYPOINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789
NEXT_PUBLIC_SKALE_BASE_MAINNET_SPONSOR_GAS=true
MERCHANT_WALLET_ADDRESS=
# --- x402 payment enforcement ---
# Primary gate: set true to enable x402 middleware for priced routes.
X402_ENABLED=true
# v0.1.0 hard enforcement: when 1, middleware activates regardless of X402_ENABLED
# and the internal-caller bypass is removed (Studio users must also submit X-Payment).
# Set to 1 for v0.1.0 production launch on SKALE Base.
X402_MANDATORY_V01=1
# When 1, X-User-Id Studio callers must pay priced routes (no bypass to credits-only path).
# Implied by X402_MANDATORY_V01=1; set independently for finer control.
X402_ENFORCE_INTERNAL=0
# Replay-protection window for nonces (seconds). Should match PROOF_VALID_SECONDS in x402Client.ts.
X402_REPLAY_WINDOW=300
# ERC-1066 / x402: wallet address that receives USDC payments on SKALE Base.
# Returned in billing.x402_challenge_response() paymentRequirements.payTo field.
X402_PAY_TO_ADDRESS=
# x402 facilitator: external service that settles ERC-3009 TransferWithAuthorization
# on SKALE Base after the orchestrator verifies the signature.
# Set X402_FACILITATOR_ENABLED=0 to skip on-chain settlement (development only).
X402_FACILITATOR_URL=https://facilitator.payai.network
X402_FACILITATOR_ENABLED=1
# x402 v2 challenge fields (orchestrator billing). USDC.e on SKALE Base Mainnet (IMA-bridged).
X402_ASSET_ADDRESS=0x85889c8c714505E0c94b30fcfcF64fE3Ac8FCb20
X402_NETWORK_CAIP=eip155:1187947933
# Kite docs recommend Pieverse for /v2/verify and /v2/settle on supported CAIP networks (e.g. eip155:2366, eip155:2368).
# SKALE is not listed on Pieverse; those payments use PayAI (X402_FACILITATOR_URL) for settle.
KITE_X402_FACILITATOR_URL=https://facilitator.pieverse.io
KITE_X402_VERIFY_ENABLED=1
KITE_X402_SETTLE_ENABLED=1
# Inbound facilitator settlement webhook: HMAC-SHA256 signing secret. Production requires this when the facilitator POSTs settlement.
# POST URL: https://<orchestrator-host>/api/v1/x402/settlement (header x-facilitator-signature). Body JSON: nonce, status (settled|failed), optional tx fields.
X402_WEBHOOK_SECRET=

# --- Kite Chain (gokite.ai — AI payment blockchain for autonomous agents) ---
# Mainnet: chainId 2366 | RPC https://rpc.gokite.ai/ | Explorer https://kitescan.ai/
# Testnet: chainId 2368 | RPC https://rpc-testnet.gokite.ai/ | Faucet https://faucet.gokite.ai
KITE_CHAIN_RPC_MAINNET=https://rpc.gokite.ai/
KITE_CHAIN_RPC_TESTNET=https://rpc-testnet.gokite.ai/

# --- Simulation fallback for non-Tenderly chains (SKALE Base) ---
SIMULATION_RPC_FALLBACK=1
# METERING_ENFORCED=
# METERING_MIN_BALANCE=0

# --- Credits (orchestrator) ---
CREDITS_ENABLED=
CREDITS_PER_USD=10
CREDITS_PER_RUN=7

# --- Pinata (IPFS; required in production for verifiable trace provenance) ---
# JWT is a secret; keep in backend (agent-runtime, storage) only. See docs.pinata.cloud/quickstart.
PINATA_JWT=
PINATA_TEMPLATE_ID=
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_WEBHOOK_SECRET=
# Use your dedicated gateway domain (e.g. example-gateway.mypinata.cloud) instead of shared gateway.pinata.cloud.
# Full URL format: https://${PINATA_GATEWAY_DOMAIN}/ipfs/{cid}. Fallback: gateway.pinata.cloud.
PINATA_GATEWAY_DOMAIN=gateway.pinata.cloud
# Legacy: full base URL. Overrides PINATA_GATEWAY_DOMAIN when set.
PINATA_GATEWAY_BASE=https://gateway.pinata.cloud/ipfs
# After insert, verify the gateway URL (HEAD/GET). Defaults to on in production (NODE_ENV/ENV=production); set 0 to disable.
STORAGE_VERIFY_RETRIEVAL=1
STORAGE_VERIFY_STRICT=1
STORAGE_RECONCILE_INTERVAL_SEC=3600
STORAGE_RECONCILE_MAX_ATTEMPTS=5

# --- Filecoin archival (Lighthouse Filecoin First; required in production) ---
# https://files.lighthouse.storage/ Open the dashboard API keys section
FILECOIN_ARCHIVAL_ENABLED=1
LIGHTHOUSE_API_KEY=
FILECOIN_FIRST_BASE=https://filecoin-first.lighthouse.storage
LIGHTHOUSE_API_BASE=https://api.lighthouse.storage

# --- Vercel (dApp hosted deployment) ---
# Required when deploy_target=vercel in POST /api/v1/workflows/{id}/ui-apps/export.
# Create at vercel.com/account/tokens.
VERCEL_TOKEN=

# --- EigenDA (trace anchoring only; not a general file bucket) ---
# Required: anchor trace blobs to EigenDA when EIGENDA_ENABLED=1.
EIGENDA_ENABLED=1
EIGENDA_PRIVATE_KEY=<your private key>
EIGENDA_DISPERSER_URL=https://disperser-holesky.eigenda.xyz

# --- ERC-8004 on-chain registration ---
# Required: POST /api/v1/identity/register to register new agent instances.
ERC8004_REGISTER_PRIVATE_KEY=
ERC8004_AGENT_URI=https://hyperkitlabs.com/agent.json

# --- Chain registry ---
REGISTRIES_PATH=./infra/registries
CHAIN_REGISTRY_PATH=./infra/registries/network/chains.yaml

# --- Services (cross-service URLs) ---
ORCHESTRATOR_URL=
AGENT_RUNTIME_URL=
VECTORDB_URL=
STORAGE_SERVICE_URL=
COMPILE_SERVICE_URL=
AUDIT_SERVICE_URL=
# Echidna fuzzing: path to harness (e.g. services/audit/echidna_harness/ERC20Harness.sol). Required for pipeline.
ECHIDNA_HARNESS_PATH=services/audit/echidna_harness/ERC20Harness.sol
ECHIDNA_TIMEOUT=60
SIMULATION_SERVICE_URL=
DEPLOY_SERVICE_URL=
TOOLS_BASE_URL=
ROMA_URL=
OPENSANDBOX_API_URL=https://api.opensandbox.ai
# --- Studio (frontend) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# API base for Studio (e.g. http://localhost:4000/api/v1 local, https://api.your-domain.com/api/v1 Coolify)
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_DOCS_URL=
# Datadog Browser RUM (optional; use RUM application id + client token from Datadog UX Monitoring)
NEXT_PUBLIC_DD_RUM_APPLICATION_ID=
NEXT_PUBLIC_DD_RUM_CLIENT_TOKEN=
NEXT_PUBLIC_DD_SITE=us5.datadoghq.com
NEXT_PUBLIC_DD_SERVICE_NAME=hyperagent-studio
# Falls back to NEXT_PUBLIC_ENV when unset
NEXT_PUBLIC_DD_ENV=
# Optional release tag for RUM (e.g. git SHA or app version)
NEXT_PUBLIC_DD_VERSION=
NEXT_PUBLIC_DD_SESSION_SAMPLE_RATE=100
NEXT_PUBLIC_DD_SESSION_REPLAY_SAMPLE_RATE=20

# --- Real-server verification (pnpm run test:e2e:real-server) ---
# Optional: STUDIO_BASE_URL, GATEWAY_BASE_URL, PLAYWRIGHT_BASE_URL. Else gateway = NEXT_PUBLIC_API_URL origin;
# Studio defaults to apex host when API is api.* (e.g. api.hyperkitlabs.com → https://hyperkitlabs.com), else http://localhost:3000 (matches next dev)

# --- Shared secrets (openssl rand -base64 32); security is mandatory ---
TOOLS_API_KEY=
# Same value on orchestrator and agent-runtime for service-to-service auth (X-Internal-Token)
INTERNAL_SERVICE_TOKEN=
AGENT_SESSION_PAYLOAD_KEY=
# Agent session JWT expiry (minutes); default 5 for short-lived BYOK tokens
AGENT_SESSION_EXP_MINUTES=5
JWT_SECRET_KEY=
# Required in production: encrypts BYOK keys at rest. Generate with: openssl rand -base64 32
LLM_KEY_ENCRYPTION_KEY=
# Prefer KMS envelope in production (master key never on the host). When BYOK_TEE_STRICT=1, KMS is required in production startup checks.
# LLM_KEY_KMS_KEY_ARN=arn:aws:kms:...
# BYOK_TEE_STRICT=0
AUTH_JWT_SECRET=
AUTH_JWT_EXPIRES_IN=86400
# Freemium: credits granted to new users on first sign-up (default 100)
FREEMIUM_INITIAL_CREDITS=100
# Auth enforced by default; set false only for local dev when needed
REQUIRE_AUTH=true

# --- SCRUBD (mandatory RE/UX validation) ---
SCRUBD_PATH=./data/SCRUBD
SCRUBD_VERSION=V6.0

# --- SCV sync (weekly Hugging Face -> RAG) ---
SCV_SYNC_ENABLED=true

# --- Exploit simulation (DeFiHackLabs PoC tests;) ---
EXPLOIT_SIM_ENABLED=true
DEFIHACKLABS_PATH=./data/DeFiHackLabs

# --- Debate (Proposer + Auditor) ---
MAX_DEBATE_ROUNDS=3

# --- Pashov solidity-auditor (AI-driven security review;) ---
# Requires packages/pashov-skills submodule. Uses BYOK via agent-runtime.
PASHOV_AUDIT_ENABLED=true
PASHOV_SKILLS_PATH=packages/pashov-skills/solidity-auditor

# --- OpenSandbox (high-security backend execution;) ---
# When enabled, compile/audit/exploit_sim run in gVisor/Firecracker sandboxes.
OPENSANDBOX_ENABLED=true
OPENSANDBOX_API_KEY=

# --- Security feed (zero-day resilience) ---
# Fetches recent exploit advisories and indexes for DesignAgent. DeFiLlama is the only public API.
DEFILLAMA_FEED_URL=https://api.llama.fi/hacks
SECURITY_FEED_TIMEOUT=10
SECURITY_FEED_MAX_EXPLOITS=5

# --- Orchestrator (for dynamic source tarball URL) ---
# When quick-demo uses workflow_id, Docker sandbox fetches tarball from this URL. Set to public orchestrator URL when behind proxy.
ORCHESTRATOR_PUBLIC_URL=

# --- Quick Demo (Docker Sandbox on Contabo) ---
# Uses SANDBOX_API_URL + OPENSANDBOX_API_KEY for Contabo Docker Sandbox API
SANDBOX_API_URL=
# OPENSANDBOX_API_KEY used for both OpenSandbox (compile/audit) and Docker sandbox (quick-demo)

# --- OpenTelemetry (spans, metrics, logs via OTLP when set) ---
# Local LGTM stack: docker compose -f infra/observability/docker-compose.yml up -d
# Production VPS with infra/docker/docker-compose.yml: send traces to the Datadog Agent OTLP receiver (same network):
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://dd-agent:4318
# Orchestrator appends /v1/traces when the URL has no path (do not point at a public host unless 4318 is reachable).
OPENTELEMETRY_ENABLED=1
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics
OTEL_SERVICE_NAME=hyperagent-orchestrator

# --- Sentry (optional; frontend + backend error capture) ---
# Create a project at https://sentry.io — never commit real DSNs to git.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Queue ---
# CELERY_ENABLED=1: route jobs through Celery (recommended for production).
#   Run workers with: celery -A celery_app worker -Q pipeline --loglevel=info
#   Monitor with Flower: celery -A celery_app flower --port=5555
# QUEUE_ENABLED=1 (legacy Redis BLPOP loop, used when CELERY_ENABLED is not set).
CELERY_ENABLED=1
QUEUE_ENABLED=1
QUEUE_MAX_RETRIES=3

# --- Postgres checkpointer ---
# When set, LangGraph persists pipeline state to Supabase Postgres (durable across restarts).
# Falls back to Redis checkpointer, then MemorySaver.
# Format: postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
SUPABASE_DB_URL=

# --- Prometheus metrics ---
# Writable directory for cross-worker metric aggregation (multi-worker Uvicorn/Gunicorn).
# If the path is missing, the orchestrator creates it; if creation fails, metrics stay in-process.
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc

# --- Orchestrator rate limits (slowapi, second layer after API-gateway Upstash limits) ---
RATE_LIMIT_ORCHESTRATOR_GENERATE=10/minute
RATE_LIMIT_ORCHESTRATOR_DEPLOY=5/minute

# --- Gateway ---
CORS_ORIGINS=http://localhost:3000,https://hyperkitlabs.com,https://api.hyperkitlabs.com
# Upstream timeout (ms). Default 25s kills SSE during long builds. Set 660000 for real-time terminal.
PROXY_TIMEOUT_MS=660000

# --- Identity HMAC (gateway signs X-User-Id, orchestrator verifies) ---
# Generate with: openssl rand -hex 32
# When set, the gateway HMAC-signs the X-User-Id header and the orchestrator rejects unsigned headers.
IDENTITY_HMAC_SECRET=
ENFORCE_IDENTITY_HMAC=1
DISABLE_IDENTITY_HMAC_ENFORCEMENT=1
# Orchestrator: require simulation_passed=true on POST .../deploy/prepare for every chain (not only mainnet).
ENFORCE_SIMULATION_BEFORE_DEPLOY=1

# --- Billing Reconciliation ---
# Interval in seconds for background billing reconciliation (default: 21600 = 6 hours). Set 0 to disable.
RECONCILIATION_INTERVAL_SEC=21600

# --- MLflow: model routing experiments + pipeline run tracking (Pillar 3) ---
# Set to your MLflow tracking server URL. Leave blank to disable (no-op).
# Local: http://localhost:5000 | Managed: https://mlflow.yourdomain.com
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT_NAME=hyperagent_pipeline

# --- Datadog APM ---
# Agent receives APM traces + DogStatsD metrics via Unix socket (/var/run/datadog/).
# DD_APM_INSTRUMENTATION_ENABLED=docker enables single-step auto-instrumentation for containers.
# Compose enables OTLP HTTP on the agent (port 4318) and sets DD_IGNORE_AUTOCONF=redisdb (managed Redis needs a password; autoconf redisdb fails otherwise).
# Create an API key at https://app.datadoghq.com/organization-settings/api-keys
DD_API_KEY=
DD_SITE=us5.datadoghq.com
DD_ENV=prod
DD_APM_ENABLED=true
DD_APM_NON_LOCAL_TRAFFIC=true
DD_DOGSTATSD_NON_LOCAL_TRAFFIC=true
DD_APM_INSTRUMENTATION_ENABLED=docker
DD_APM_INSTRUMENTATION_LIBRARIES=java:1,python:4,js:5,php:1,dotnet:3,ruby:2
DD_LOGS_ENABLED=true
DD_LOGS_CONFIG_CONTAINER_COLLECT_ALL=true
DD_TRACE_OPENAI_AGENTS_ENABLED=false