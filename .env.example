# Application
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# Core infra
# ----------------------------------------------------------------------------

# Database
# Use a standard URL so both Python and TS services can parse it.
# Matches docker-compose.yml default credentials
DATABASE_URL=postgresql://hyperagent_user:secure_password@localhost:5432/hyperagent_db

# Redis
REDIS_URL=redis://localhost:6379/0

# ----------------------------------------------------------------------------
# LLM Providers
# ----------------------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_THINKING_BUDGET=8192

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4.5

# ----------------------------------------------------------------------------
# TS-first API (Fastify) settings
# ----------------------------------------------------------------------------
TS_API_PORT=4000
PYTHON_BACKEND_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# Blockchain
# ----------------------------------------------------------------------------
PRIVATE_KEY=

# Optional overrides for specific networks (JSON object mapping network -> rpcUrl)
# For most chains you can omit this and rely on Thirdweb RPC fallback (requires THIRDWEB_CLIENT_ID).
RPC_URLS={"avalanche_fuji":"https://api.avax-test.network/ext/bc/C/rpc","mantle_testnet":"https://rpc.sepolia.mantle.xyz"}

# Server Wallet (for gasless deployments)
SERVER_WALLET_ADDRESS=

# ----------------------------------------------------------------------------
# Thirdweb / x402
# ----------------------------------------------------------------------------

# Needed for Thirdweb RPC fallback across 170+ EVM networks:
#   https://<chainId>.rpc.thirdweb.com/<THIRDWEB_CLIENT_ID>
THIRDWEB_CLIENT_ID=
THIRDWEB_SECRET_KEY=
THIRDWEB_SERVER_WALLET_ADDRESS=

# Required by TS API + Python API for manual USDC transfers
MERCHANT_WALLET_ADDRESS=

# x402 Payment Configuration
X402_ENABLED=true

# Comma-separated list of networks where the API should enforce x402 payments.
# Supports:
# - network keys (e.g. avalanche_fuji)
# - chain ids (e.g. 56)
# - CAIP-2 (e.g. eip155:56)
# - wildcards: * or all
#
# Examples:
# X402_ENABLED_NETWORKS=avalanche_fuji,avalanche_mainnet
# X402_ENABLED_NETWORKS=*
X402_ENABLED_NETWORKS=avalanche_fuji,avalanche_mainnet

# Optional: pricing tiers in USD
X402_PRICE_TIERS={"basic":0.01,"advanced":0.02,"deployment":0.10}

# TS API talks to the x402-verifier service
# - Docker default: http://x402-verifier:3001 (set via docker-compose)
# - Host default when using docker-compose port mapping: http://localhost:3002
X402_VERIFIER_URL=http://localhost:3002

# Python API talks to the x402-verifier service
# - Docker default is set via docker-compose (X402_SERVICE_URL)
X402_SERVICE_URL=http://localhost:3002

# ERC-4337 (Account Abstraction)
# NOTE: ERC-4337 paymaster deployments are not supported in this release.
ENTRYPOINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
FACTORY_ADDRESS=

# ----------------------------------------------------------------------------
# EigenDA
# ----------------------------------------------------------------------------
EIGENDA_DISPERSER_URL=https://disperser.eigenda.xyz
EIGENDA_USE_AUTHENTICATED=false

# ----------------------------------------------------------------------------
# Mantle SDK
# ----------------------------------------------------------------------------
MANTLE_TESTNET_RPC=https://rpc.testnet.mantle.xyz
MANTLE_MAINNET_RPC=https://rpc.mantle.xyz

# ----------------------------------------------------------------------------
# Monitoring & analytics
# ----------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://localhost:5000
PROMETHEUS_PORT=9090
DUNE_API_KEY=

# ----------------------------------------------------------------------------
# RAG
# ----------------------------------------------------------------------------
FIRECRAWL_API_KEY=
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=hyperagent-contracts

# Moralis (Webhooks)
MORALIS_API_KEY=

# ----------------------------------------------------------------------------
# Secrets Management
# ----------------------------------------------------------------------------
SECRETS_MODE=env
AWS_SECRETS_REGION=us-east-1
VAULT_URL=

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
DEPLOYMENT_RATE_LIMIT_PER_WALLET=10
DEPLOYMENT_RATE_LIMIT_PER_NETWORK=100

# ----------------------------------------------------------------------------
# Frontend (public)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=

# ----------------------------------------------------------------------------
# Cost Estimation
# ----------------------------------------------------------------------------
CREDIT_TO_USDC_RATE=0.001
BASE_OPERATION_CREDITS=10

# Default Spending Limits
DEFAULT_DAILY_LIMIT_USDC=10.0
DEFAULT_MONTHLY_LIMIT_USDC=100.0

# Token Costs (for profit tracking, per 1K tokens)
GEMINI_INPUT_COST_PER_1K=0.000001
GEMINI_OUTPUT_COST_PER_1K=0.000002
GPT4_INPUT_COST_PER_1K=0.00001
GPT4_OUTPUT_COST_PER_1K=0.00003
CLAUDE_OPUS_INPUT_COST_PER_1K=0.000015
CLAUDE_OPUS_OUTPUT_COST_PER_1K=0.000075
LLAMA_405B_INPUT_COST_PER_1K=0.000002
LLAMA_405B_OUTPUT_COST_PER_1K=0.000004
