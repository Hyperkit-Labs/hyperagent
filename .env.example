NODE_ENV=production
LOG_LEVEL=INFO

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
DATABASE_URL=

# --- Redis ---
REDIS_URL=

# --- Tenderly (simulation) ---
TENDERLY_API_KEY=
TENDERLY_ACCOUNT=
TENDERLY_PROJECT=
TENDERLY_API_URL=

# --- Thirdweb / x402 ---
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=
THIRDWEB_SECRET_KEY=
THIRDWEB_SERVER_WALLET_ADDRESS=
MERCHANT_WALLET_ADDRESS=
X402_ENABLED=true

# --- Pinata (IPFS) ---
PINATA_JWT=
PINATA_TEMPLATE_ID=
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_GATEWAY_BASE=https://gateway.pinata.cloud/ipfs

# --- LLM / Embeddings (BYOK: users provide at runtime; scripts only) ---
GEMINI_API_KEY=
EMBED_MODEL=text-embedding-3-small

# --- Chain registry ---
REGISTRIES_PATH=
CHAIN_REGISTRY_PATH=
CHAIN_REGISTRY_URL=

# --- Services (cross-service URLs) ---
ORCHESTRATOR_URL=
AGENT_RUNTIME_URL=
STORAGE_SERVICE_URL=
COMPILE_SERVICE_URL=
AUDIT_SERVICE_URL=
SIMULATION_SERVICE_URL=
DEPLOY_SERVICE_URL=
ROMA_URL=

# --- Render URLs ---
TOOLS_BASE_URL=

# --- Studio (frontend) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_DOCS_URL=

# --- Shared secrets (openssl rand -base64 32) ---
TOOLS_API_KEY=
INTERNAL_SERVICE_TOKEN=
AGENT_SESSION_PAYLOAD_KEY=
JWT_SECRET_KEY=
LLM_KEY_ENCRYPTION_KEY=
AUTH_JWT_SECRET=
AUTH_JWT_EXPIRES_IN=86400
REQUIRE_AUTH=true

# --- Gateway ---
CORS_ORIGINS=http://localhost:3000 # Replace with your actual domain
