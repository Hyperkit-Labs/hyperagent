NODE_ENV=production
LOG_LEVEL=INFO

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
DATABASE_URL=

# --- Redis ---
REDIS_URL=

# --- Tenderly (simulation) ---
TENDERLY_API_KEY=
TENDERLY_ACCOUNT=
TENDERLY_PROJECT=
TENDERLY_API_URL=

# --- Thirdweb / x402 ---
THIRDWEB_CLIENT_ID=
THIRDWEB_SECRET_KEY=
THIRDWEB_SERVER_WALLET_ADDRESS=
MERCHANT_WALLET_ADDRESS=
X402_ENABLED=true

# --- Pinata (IPFS) ---
PINATA_JWT=
PINATA_TEMPLATE_ID=
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_GATEWAY_BASE=https://gateway.pinata.cloud/ipfs

# --- Shared secrets (openssl rand -base64 32) ---
INTERNAL_SERVICE_TOKEN=
TOOLS_API_KEY=
AGENT_SESSION_PAYLOAD_KEY=
JWT_SECRET_KEY=
AUTH_JWT_SECRET=
AUTH_JWT_EXPIRES_IN=86400
REQUIRE_AUTH=true

# --- Gateway ---
CORS_ORIGINS=http://localhost:3000,https://ai.hyperionkit.xyz

# --- Cross-service URLs (set after deploy; use actual Render URLs) ---
ORCHESTRATOR_URL=
AGENT_RUNTIME_URL=
ROMA_SERVICE_URL=
SIMULATION_SERVICE_URL=
DEPLOY_SERVICE_URL=
STORAGE_SERVICE_URL=
COMPILE_SERVICE_URL=
AUDIT_SERVICE_URL=
TOOLS_BASE_URL=

# --- ROMA service (hyperagent-roma) ---
# AGENT_RUNTIME_URL=  # for roma fallback when ROMA_API_URL unset
# ROMA_API_URL=       # optional: external ROMA product API