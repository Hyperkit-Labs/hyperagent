NODE_ENV=production
LOG_LEVEL=INFO

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_PASSWORD=
DATABASE_URL=

# --- Redis (gateway rate limit; use rediss:// for TLS) ---
REDIS_URL=
REDIS_TLS_VERIFY=true
RATE_LIMIT_BYPASS_ON_FAIL=true
RATE_LIMIT_MAX_IP=300
RATE_LIMIT_MAX_USER=500
RATE_LIMIT_MULTIPLIER=2

# --- Tenderly (simulation) ---
TENDERLY_API_KEY=
TENDERLY_ACCOUNT=
TENDERLY_PROJECT=
TENDERLY_API_URL=

# --- Thirdweb / x402 ---
THIRDWEB_CLIENT_ID=
THIRDWEB_SECRET_KEY=
THIRDWEB_SERVER_WALLET_ADDRESS=
MERCHANT_WALLET_ADDRESS=
X402_ENABLED=true

# --- Credits (orchestrator) ---
CREDITS_ENABLED=true
CREDITS_PER_USD=10
CREDITS_PER_RUN=7

# --- Chain registry ---
REGISTRIES_PATH=./infra/registries
CHAIN_REGISTRY_PATH=./infra/registries/network/chains.yaml

# --- Pinata (IPFS) ---
PINATA_JWT=
PINATA_TEMPLATE_ID=
PINATA_API_KEY=
PINATA_API_SECRET=
PINATA_GATEWAY_BASE=https://gateway.pinata.cloud/ipfs

# --- Shared secrets (openssl rand -base64 32) ---
INTERNAL_SERVICE_TOKEN=
TOOLS_API_KEY=
AGENT_SESSION_PAYLOAD_KEY=
JWT_SECRET_KEY=
LLM_KEY_ENCRYPTION_KEY=
AUTH_JWT_SECRET=
AUTH_JWT_EXPIRES_IN=86400
REQUIRE_AUTH=true

# --- Gateway ---
CORS_ORIGINS=http://localhost:3000,https://ai.hyperionkit.xyz

# --- Cross-service URLs (set after deploy; use actual Render URLs) ---
ORCHESTRATOR_URL=
AGENT_RUNTIME_URL=
VECTORDB_URL=
ROMA_URL=
SIMULATION_SERVICE_URL=
DEPLOY_SERVICE_URL=
STORAGE_SERVICE_URL=
COMPILE_SERVICE_URL=
AUDIT_SERVICE_URL=
TOOLS_BASE_URL=
OPENSANDBOX_API_URL=https://api.opensandbox.ai
# --- OpenSandbox (Hosted: https://api.opensandbox.ai or self-hosted URL) ---
OPENSANDBOX_ENABLED=true
OPENSANDBOX_API_KEY=
OPENSANDBOX_API_URL=

# --- SCRUBD (mandatory RE/UX validation) ---
SCRUBD_PATH=./data/SCRUBD
SCRUBD_VERSION=V6.0

# --- Pashov solidity-auditor (production-required) ---
PASHOV_AUDIT_ENABLED=true
PASHOV_SKILLS_PATH=packages/pashov-skills/solidity-auditor

# --- Debate (Proposer + Auditor) ---
MAX_DEBATE_ROUNDS=3

# --- Quick Demo (Docker Sandbox on Contabo) ---
SANDBOX_API_URL=
# OPENSANDBOX_API_KEY used for both OpenSandbox (compile/audit) and Docker sandbox (quick-demo)