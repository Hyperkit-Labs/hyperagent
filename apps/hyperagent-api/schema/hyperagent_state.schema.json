{
  "$ref": "#/definitions/HyperAgentState",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "HyperAgentMeta": {
      "$ref": "#/definitions/HyperAgentMetaV1"
    },
    "HyperAgentMetaV1": {
      "additionalProperties": false,
      "description": "Schema-locked meta extension. This is the ONLY allowed top-level extension beyond the 7 core fields.",
      "properties": {
        "billing": {
          "additionalProperties": false,
          "properties": {
            "paymentRequired": {
              "type": "boolean"
            },
            "priceUsd": {
              "type": "number"
            },
            "x402Enabled": {
              "type": "boolean"
            }
          },
          "required": [
            "x402Enabled",
            "priceUsd",
            "paymentRequired"
          ],
          "type": "object"
        },
        "chains": {
          "additionalProperties": false,
          "properties": {
            "requested": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "selected": {
              "type": "string"
            }
          },
          "required": [
            "selected",
            "requested"
          ],
          "type": "object"
        },
        "contracts": {
          "additionalProperties": false,
          "properties": {
            "items": {
              "items": {
                "additionalProperties": false,
                "properties": {
                  "filename": {
                    "type": "string"
                  },
                  "id": {
                    "type": "string"
                  }
                },
                "required": [
                  "id",
                  "filename"
                ],
                "type": "object"
              },
              "type": "array"
            },
            "primaryId": {
              "type": "string"
            }
          },
          "required": [
            "primaryId",
            "items"
          ],
          "type": "object"
        },
        "createdAt": {
          "type": "string"
        },
        "execution": {
          "additionalProperties": false,
          "properties": {
            "maxSteps": {
              "type": "number"
            },
            "step": {
              "type": "number"
            }
          },
          "required": [
            "step",
            "maxSteps"
          ],
          "type": "object"
        },
        "updatedAt": {
          "type": "string"
        },
        "version": {
          "const": "v1",
          "type": "string"
        },
        "workflowId": {
          "type": "string"
        }
      },
      "required": [
        "version",
        "workflowId",
        "createdAt",
        "updatedAt",
        "execution",
        "chains",
        "contracts",
        "billing"
      ],
      "type": "object"
    },
    "HyperAgentState": {
      "additionalProperties": false,
      "description": "Full spec-locked state for orchestrator.",
      "properties": {
        "auditResults": {
          "additionalProperties": false,
          "properties": {
            "findings": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "passed": {
              "type": "boolean"
            }
          },
          "required": [
            "passed",
            "findings"
          ],
          "type": "object"
        },
        "contract": {
          "type": "string"
        },
        "deploymentAddress": {
          "type": "string"
        },
        "intent": {
          "type": "string"
        },
        "logs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "meta": {
          "$ref": "#/definitions/HyperAgentMeta"
        },
        "status": {
          "$ref": "#/definitions/HyperAgentStatus"
        },
        "txHash": {
          "type": "string"
        }
      },
      "required": [
        "auditResults",
        "contract",
        "deploymentAddress",
        "intent",
        "logs",
        "meta",
        "status",
        "txHash"
      ],
      "type": "object"
    },
    "HyperAgentStatus": {
      "description": "DESIGN TOKEN: State Shape This is the COMPLETE state object. Nothing else is added. All 7 fields present on every state transition. No optional fields, no extra properties.",
      "enum": [
        "processing",
        "auditing",
        "validating",
        "deploying",
        "success",
        "failed"
      ],
      "type": "string"
    }
  }
}