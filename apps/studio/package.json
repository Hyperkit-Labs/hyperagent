{
  "name": "hyperagent-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:docker": "next dev --hostname 0.0.0.0 --webpack",
    "verify:public-build-env": "node ./scripts/assert-public-build-env.cjs",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint . --max-warnings 999",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "node ./scripts/run-jest.cjs",
    "test:e2e": "node ./scripts/playwright-env.mjs exec playwright test",
    "test:e2e:auth": "node ./scripts/playwright-env.mjs exec playwright test \"e2e/auth-redirect.spec.ts\" --reporter=list",
    "test:e2e:real-server": "node ./scripts/run-real-server-verification.mjs",
    "test:e2e:ui": "node ./scripts/playwright-env.mjs exec playwright test --ui",
    "ci": "npm ci && npm run lint && npm test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@ai-sdk/react": "^3.0.136",
    "@datadog/browser-rum": "^6.32.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@emotion/use-insertion-effect-with-fallbacks": "^1.2.0",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@hyperagent/api-contracts": "workspace:*",
    "@hyperagent/config": "workspace:*",
    "@hyperagent/frontend-data": "workspace:*",
    "@hyperagent/workflow-state": "workspace:*",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.47.0",
    "@supabase/supabase-js": "^2.47.0",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@vercel/analytics": "^2.0.1",
    "@x402/evm": "^2.10.0",
    "@x402/fetch": "^2.10.0",
    "@xstate/react": "^5.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "~4.3.19",
    "animejs": "^3.2.2",
    "axios": "^1.13.5",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3-force": "^3.0.0",
    "date-fns": "^4.1.0",
    "dd-trace": "^5.97.0",
    "dotenv": "^17.3.1",
    "framer-motion": "^11.18.2",
    "hyperkit-erc1066": "^0.1.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.577.0",
    "next": "16.2.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-syntax-highlighter": "^16.1.1",
    "react-use-measure": "^2.1.7",
    "recharts": "^3.4.1",
    "siwe": "^2.1.6",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "thirdweb": "^5.119.4",
    "vaul": "^1.1.2",
    "viem": "2.39.0",
    "zustand": "^5.0.12"
  },
  "optionalDependencies": {
    "@next/swc-darwin-arm64": "16.2.2",
    "@next/swc-darwin-x64": "16.2.2",
    "@next/swc-linux-arm64-gnu": "16.2.2",
    "@next/swc-linux-arm64-musl": "16.2.2",
    "@next/swc-linux-x64-gnu": "16.2.2",
    "@next/swc-linux-x64-musl": "16.2.2",
    "@next/swc-win32-arm64-msvc": "16.2.2",
    "@next/swc-win32-x64-msvc": "16.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.0",
    "@types/animejs": "^3.1.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "babel-jest": "^29.7.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "msw": "^2.12.0",
    "prettier": "^3.2.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
