# HyperAgent Tools - remote heavy toolchain (Foundry, Hardhat, Slither, Mythril).
# Phase 1: FastAPI with dummy responses. Phase 2: add foundryup, node, slither, mythril.
# Build from repo root: docker build -f infra/docker/Dockerfile.hyperagent-tools .
FROM python:3.11-slim

WORKDIR /app

# Use venv to avoid "Running pip as root" warning
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

COPY services/hyperagent-tools/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY services/hyperagent-tools/main.py .

EXPOSE 9000

# Use PORT from env (Render sets this); fallback to 9000 for local/docker-compose
CMD ["sh", "-c", "uvicorn main:app --host 0.0.0.0 --port ${PORT:-9000}"]
