FROM node:20-alpine AS base
WORKDIR /app
# Monorepo: Studio uses pnpm workspace (workspace:*). Copy root and workspace members.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/studio ./apps/studio
COPY packages ./packages
RUN corepack enable pnpm && pnpm install --frozen-lockfile
WORKDIR /app/apps/studio

# Build-time public env (Coolify / CI: pass as build-args so Next inlines real URLs, not localhost).
# Placed after install so changing only NEXT_PUBLIC_* does not invalidate the pnpm install layer.
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_THIRDWEB_CLIENT_ID
ARG NEXT_PUBLIC_ENV
ARG NEXT_PUBLIC_DOCS_URL=""
ARG NEXT_PUBLIC_SUPABASE_URL=""
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY=""
ARG NEXT_PUBLIC_X402_VERIFIER_URL=""
ARG NEXT_PUBLIC_DD_RUM_APPLICATION_ID=""
ARG NEXT_PUBLIC_DD_RUM_CLIENT_TOKEN=""
ARG NEXT_PUBLIC_DD_SITE=""
ARG NEXT_PUBLIC_DD_SERVICE_NAME=""
ARG NEXT_PUBLIC_DD_ENV=""
ARG NEXT_PUBLIC_DD_VERSION=""
ARG NEXT_PUBLIC_APP_VERSION=""
ARG NEXT_PUBLIC_DD_SESSION_SAMPLE_RATE=""
ARG NEXT_PUBLIC_DD_SESSION_REPLAY_SAMPLE_RATE=""
ARG NEXT_PUBLIC_DD_RUM_DEBUG=""
ARG NEXT_PUBLIC_SENTRY_DSN=""
ARG NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=""
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_THIRDWEB_CLIENT_ID=$NEXT_PUBLIC_THIRDWEB_CLIENT_ID
ENV NEXT_PUBLIC_ENV=$NEXT_PUBLIC_ENV
ENV NEXT_PUBLIC_DOCS_URL=$NEXT_PUBLIC_DOCS_URL
ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
ENV NEXT_PUBLIC_X402_VERIFIER_URL=$NEXT_PUBLIC_X402_VERIFIER_URL
ENV NEXT_PUBLIC_DD_RUM_APPLICATION_ID=$NEXT_PUBLIC_DD_RUM_APPLICATION_ID
ENV NEXT_PUBLIC_DD_RUM_CLIENT_TOKEN=$NEXT_PUBLIC_DD_RUM_CLIENT_TOKEN
ENV NEXT_PUBLIC_DD_SITE=$NEXT_PUBLIC_DD_SITE
ENV NEXT_PUBLIC_DD_SERVICE_NAME=$NEXT_PUBLIC_DD_SERVICE_NAME
ENV NEXT_PUBLIC_DD_ENV=$NEXT_PUBLIC_DD_ENV
ENV NEXT_PUBLIC_DD_VERSION=$NEXT_PUBLIC_DD_VERSION
ENV NEXT_PUBLIC_APP_VERSION=$NEXT_PUBLIC_APP_VERSION
ENV NEXT_PUBLIC_DD_SESSION_SAMPLE_RATE=$NEXT_PUBLIC_DD_SESSION_SAMPLE_RATE
ENV NEXT_PUBLIC_DD_SESSION_REPLAY_SAMPLE_RATE=$NEXT_PUBLIC_DD_SESSION_REPLAY_SAMPLE_RATE
ENV NEXT_PUBLIC_DD_RUM_DEBUG=$NEXT_PUBLIC_DD_RUM_DEBUG
ENV NEXT_PUBLIC_SENTRY_DSN=$NEXT_PUBLIC_SENTRY_DSN
ENV NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=$NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE

RUN node ./scripts/assert-public-build-env.cjs
RUN pnpm run build
EXPOSE 3000
CMD ["pnpm", "start"]
