{
  "name": "hyperagent",
  "version": "0.1.0",
  "description": "AI-powered smart contract development platform",
  "private": true,
  "scripts": {
    "dev": "pnpm turbo dev",
    "build": "pnpm turbo build",
    "lint": "pnpm turbo lint",
    "typecheck": "pnpm turbo typecheck",
    "test": "pnpm turbo test",
    "contracts:generate": "pnpm --filter @hyperagent/api-contracts run generate",
    "contracts:artifacts:check": "git diff --exit-code -- packages/api-contracts/openapi/openapi.json packages/api-contracts/openapi/spec-lock.schema.json packages/api-contracts/src/generated/schema.ts packages/api-contracts/src/generated/spec-lock.schema.ts packages/schema-registry/manifest.json packages/schema-registry/spec-contracts/v1/spec-lock.schema.json packages/schema-registry/fixtures/spec-contracts/spec-lock-valid.json",
    "schema:validate": "python3 scripts/schema/validate_registry.py",
    "spec-contract:check": "python3 scripts/schema/export_spec_contract.py --check",
    "test:contracts:schemathesis": "bash scripts/api/run_schemathesis.sh",
    "security:semgrep": "semgrep scan --config .semgrep/hyperagent.yml --config p/ci --config p/r2c-security-audit --config p/python --config p/typescript --config p/secrets .",
    "openapi:lint": "pnpm --package=@redocly/cli@2 dlx redocly lint orchestrator@v1 --config redocly.yaml",
    "test:minimal": "node scripts/minimal-suite/run.mjs",
    "test:minimal:all": "node scripts/minimal-suite/run.mjs --all",
    "test:ai-tools": "pnpm turbo run build test --filter=@hyperagent/ai-tools",
    "format": "pnpm turbo format",
    "ci:preflight": "node scripts/ci-preflight.cjs",
    "ci:preflight:full": "node scripts/ci-preflight-full.cjs",
    "ci:gate:contracts": "pnpm run contracts:generate && pnpm run contracts:artifacts:check && pnpm run schema:validate && pnpm run openapi:lint",
    "ci:gate:pr": "pnpm run ci:gate:contracts && pnpm run ci:preflight:full",
    "commit": "node .github/version/scripts/commit/cli/index.js commit",
    "commit:dry": "node .github/version/scripts/commit/cli/index.js commit --dry-run",
    "commit:sh": "bash .github/version/scripts/commit/parallel-commit.sh",
    "commit:sh:dry": "bash .github/version/scripts/commit/parallel-commit.sh --dry-run",
    "commit:all": "git add -A && git commit -m 'chore: update all changes'",
    "commit:auto": "node .github/version/scripts/commit/cli/index.js commit --max 3",
    "commit:cli": "node .github/version/scripts/commit/cli/index.js",
    "security:check": "node .github/version/scripts/commit/cli/index.js security",
    "audit": "pnpm audit",
    "audit:fix": "pnpm audit --fix",
    "status": "git status",
    "changes": "git status --porcelain",
    "staged": "git diff --cached --name-only",
    "db:apply-migrations": "node tools/db/apply-supabase-migrations.mjs",
    "db:verify-security": "node tools/db/verify-supabase-security.mjs",
    "db:ci-setup-rls-test-users": "node tools/db/ci-setup-rls-test-users.mjs",
    "docs:auth-snapshots": "node scripts/export-auth-snapshots.mjs",
    "verify:studio-public-env": "pnpm --filter hyperagent-studio run verify:public-build-env",
    "dev:ordered": "node scripts/dev-ordered.mjs",
    "dev:ordered:stack": "node scripts/dev-ordered.mjs --with-backend",
    "test:e2e:real-server": "pnpm --filter hyperagent-studio run test:e2e:real-server",
    "prepare": "husky"
  },
  "keywords": [
    "smart-contracts",
    "ai",
    "web3",
    "blockchain",
    "hyperagent"
  ],
  "author": "HyperKit Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hyperkit-Labs/hyperagent.git"
  },
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "resolutions": {
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "@emotion/use-insertion-effect-with-fallbacks": "^1.1.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@emotion/use-insertion-effect-with-fallbacks": "^1.2.0",
    "vercel": "^50.28.0"
  },
  "devDependencies": {
    "@babel/runtime": "^7.28.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@rollup/rollup-win32-x64-msvc": "4.60.2",
    "@vitest/utils": "4.1.4",
    "dotenv": "^16.4.7",
    "husky": "^9.1.7",
    "lightningcss-win32-x64-msvc": "1.31.1",
    "lint-staged": "^15.5.2",
    "pg": "^8.14.1",
    "turbo": "^2.9.6"
  },
  "pnpm": {
    "packageExtensions": {
      "lightningcss": {
        "optionalDependencies": {
          "lightningcss-win32-x64-msvc": "1.31.1"
        }
      },
      "rollup": {
        "optionalDependencies": {
          "@rollup/rollup-win32-x64-msvc": "4.60.2"
        }
      }
    },
    "overrides": {
      "react": "19.2.5",
      "react-dom": "19.2.5",
      "@emotion/use-insertion-effect-with-fallbacks": "^1.1.0",
      "thirdweb": "5.119.4",
      "axios": ">=1.15.0",
      "hono": ">=4.12.14",
      "tar": ">=7.5.10",
      "minimatch": ">=10.2.3",
      "bn.js": ">=5.2.3",
      "jsondiffpatch": ">=0.7.2",
      "nanoid": ">=3.3.8",
      "ajv@>=8": ">=8.18.0",
      "@tootallnate/once": ">=3.0.1",
      "undici": ">=7.24.0",
      "follow-redirects": ">=1.16.0",
      "fast-uri": ">=3.1.2",
      "semver": ">=7.6.3",
      "json5": ">=2.2.3",
      "ws": ">=8.18.0",
      "express": ">=4.21.0",
      "jsonwebtoken": ">=9.0.2",
      "esbuild@<=0.24.2": ">=0.25.0",
      "@hono/node-server@<1.19.13": ">=1.19.13",
      "basic-ftp@<=5.2.2": ">=5.3.0",
      "uuid@<14.0.0": ">=14.0.0",
      "devalue@<5.8.1": ">=5.8.1",
      "devalue@<=5.8.0": ">=5.8.1",
      "flatted@<3.4.0": ">=3.4.0",
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "undici@>=7.17.0 <7.24.0": ">=7.24.0",
      "next@>=16.0.0-beta.0 <16.2.6": ">=16.2.6",
      "flatted@<=3.4.1": ">=3.4.2",
      "next@>=16.0.1 <16.2.6": ">=16.2.6",
      "h3@<1.15.9": ">=1.15.9",
      "h3@<=1.15.8": ">=1.15.9",
      "ai@>=4.0.0 <5.0.52": ">=5.0.179",
      "@noble/hashes": "1.8.0",
      "socket.io-parser@>=4.0.0 <4.2.6": ">=4.2.6",
      "@ai-sdk/anthropic": "^3.0.69",
      "smol-toml@<1.6.1": ">=1.6.1",
      "srvx@<0.11.13": ">=0.11.13",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "picomatch@4.0.3": "4.0.4",
      "micromatch>picomatch": "4.0.4",
      "yaml@>=1.0.0 <1.10.3": ">=1.10.3",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "path-to-regexp@>=4.0.0 <6.3.0": ">=6.3.0",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "protobufjs@<8.0.2": ">=8.0.2",
      "@opentelemetry/sdk-node@<0.217.0": ">=0.217.0",
      "colorette": "2.0.20"
    }
  }
}
