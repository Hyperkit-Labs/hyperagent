{
  "name": "hyperagent",
  "version": "0.1.0",
  "description": "AI-powered smart contract development platform",
  "private": true,
  "scripts": {
    "commit": "node scripts/git/version/scripts/parallel-commit.js",
    "commit:dry": "node scripts/git/version/scripts/parallel-commit.js --dry-run",
    "commit:sh": "bash scripts/git/version/scripts/parallel-commit.sh",
    "commit:sh:dry": "bash scripts/git/version/scripts/parallel-commit.sh --dry-run",
    "commit:all": "git add -A && git commit -m \"chore: update project files\"",
    "commit:auto": "bash scripts/git/version/scripts/parallel-commit.sh --max 3",
    "status": "git status",
    "changes": "git status --porcelain",
    "staged": "git diff --cached --name-only",
    "add": "git add",
    "push": "git push",
    "pull": "git pull",
    "branch": "git branch",
    "checkout": "git checkout",
    "merge": "git merge",
    "rebase": "git rebase",
    "log": "git log --oneline --graph --decorate",
    "diff": "git diff",
    "reset": "git reset",
    "clean": "git clean -fd"
  },
  "keywords": [
    "smart-contracts",
    "ai",
    "web3",
    "blockchain",
    "hyperagent"
  ],
  "author": "HyperKit Labs",
  "license": "MIT"
}

