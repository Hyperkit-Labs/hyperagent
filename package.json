{
  "name": "hyperagent",
  "version": "0.1.0",
  "description": "AI-powered smart contract development platform",
  "private": true,
  "scripts": {
    "dev": "pnpm turbo dev",
    "build": "pnpm turbo build",
    "lint": "pnpm turbo lint",
    "typecheck": "pnpm turbo typecheck",
    "test": "pnpm turbo test",
    "format": "pnpm turbo format",
    "commit": "node tools/scripts/version/parallel-commit.js",
    "commit:dry": "node tools/scripts/version/parallel-commit.js --dry-run",
    "commit:sh": "bash tools/scripts/version/parallel-commit.sh",
    "commit:sh:dry": "bash tools/scripts/version/parallel-commit.sh --dry-run",
    "commit:all": "git add -A && git commit -m 'chore: update all changes'",
    "commit:auto": "bash tools/scripts/version/parallel-commit.sh --max 3",
    "status": "git status",
    "changes": "git status --porcelain",
    "staged": "git diff --cached --name-only"
  },
  "keywords": [
    "smart-contracts",
    "ai",
    "web3",
    "blockchain",
    "hyperagent"
  ],
  "author": "HyperKit Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hyperkit-Labs/hyperagent.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "resolutions": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "@emotion/use-insertion-effect-with-fallbacks": "^1.1.0"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@emotion/use-insertion-effect-with-fallbacks": "^1.2.0"
  }
}
