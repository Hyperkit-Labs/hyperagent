{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hyperkitlabs.com/schemas/run-model.json",
  "title": "RunModel",
  "description": "Canonical Run data contract for Phase B. Referenced by TS (core-types) and Python (orchestrator).",
  "definitions": {
    "Run": {
      "type": "object",
      "required": ["id", "status"],
      "properties": {
        "id": { "type": "string", "format": "uuid", "description": "run_id (UUID)" },
        "workflow_id": { "type": "string", "format": "uuid" },
        "project_id": { "type": "string", "format": "uuid" },
        "status": { "type": "string", "enum": ["pending", "running", "success", "failed", "cancelled"] },
        "current_stage": { "type": "string" },
        "current_step": { "type": "integer", "description": "Index of current step in plan" },
        "workflow_version": { "type": "string" },
        "error_message": { "type": ["string", "null"] },
        "started_at": { "type": ["string", "null"], "format": "date-time" },
        "ended_at": { "type": ["string", "null"], "format": "date-time" },
        "completed_at": { "type": ["string", "null"], "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" },
        "steps": { "type": "array", "items": { "$ref": "#/definitions/RunStep" } },
        "artifacts": { "type": "array", "items": { "$ref": "#/definitions/ArtifactRef" } },
        "security_findings": { "type": "array", "items": { "$ref": "#/definitions/SecurityFindingRef" } }
      }
    },
    "RunPlan": {
      "type": "object",
      "required": ["step_types"],
      "properties": {
        "step_types": {
          "type": "array",
          "items": { "type": "string", "enum": ["spec", "design", "codegen", "audit", "simulation", "deploy", "ui_scaffold"] }
        }
      }
    },
    "RunStep": {
      "type": "object",
      "required": ["run_id", "step_index", "step_type", "status"],
      "properties": {
        "run_id": { "type": "string", "format": "uuid" },
        "step_index": { "type": "integer" },
        "step_type": { "type": "string", "enum": ["spec", "design", "codegen", "audit", "simulation", "deploy", "ui_scaffold"] },
        "status": { "type": "string", "enum": ["pending", "running", "completed", "failed"] },
        "input_summary": { "type": ["string", "null"] },
        "output_summary": { "type": ["string", "null"] },
        "error_message": { "type": ["string", "null"] },
        "trace_blob_id": { "type": ["string", "null"] },
        "trace_da_cert": { "type": ["string", "null"] },
        "trace_reference_block": { "type": ["string", "null"] },
        "started_at": { "type": ["string", "null"], "format": "date-time" },
        "completed_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "ArtifactRef": {
      "type": "object",
      "required": ["type", "storage_ref", "run_id"],
      "properties": {
        "type": { "type": "string", "enum": ["contract", "test", "abi", "audit_report", "simulation_report", "deployment_record", "design_doc"] },
        "storage_ref": { "type": "string", "description": "CID (IPFS) or blob_id" },
        "run_id": { "type": "string", "format": "uuid" },
        "step_index": { "type": "integer" },
        "hash": { "type": "string", "description": "Content hash for lineage" },
        "version": { "type": "string" }
      }
    },
    "SecurityFindingRef": {
      "type": "object",
      "required": ["run_id", "severity", "title"],
      "properties": {
        "run_id": { "type": "string", "format": "uuid" },
        "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "source_tool": { "type": "string" }
      }
    }
  },
  "oneOf": [
    { "$ref": "#/definitions/Run" },
    { "$ref": "#/definitions/RunPlan" },
    { "$ref": "#/definitions/RunStep" }
  ]
}
