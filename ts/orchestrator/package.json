{
  "name": "@hyperagent/orchestrator",
  "version": "0.1.0",
  "description": "Spec-locked HyperAgent orchestrator implementing DNA blueprint",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "schema:generate": "ts-json-schema-generator --path src/core/spec/state.ts --type HyperAgentState --out ../../schema/hyperagent_state.schema.json",
    "prepare": "npm run build"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-json-schema-generator": "^1.5.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  }
}

